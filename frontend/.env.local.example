# Copy to .env.local and fill in values
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your-map-id

# TD-21 (Sprint 29) — server-side only; never NEXT_PUBLIC_*.
# Same value as REVALIDATE_TOKEN on the api Cloud Run service. The
# revalidate route handler returns 503 when this is unset, 401 when
# the request's X-Revalidate-Token doesn't match. Set on Cloud Run
# WEB service via `gcloud run deploy --update-env-vars REVALIDATE_TOKEN=...`.
# REVALIDATE_TOKEN=<opaque-secret-shared-between-api-and-web>
