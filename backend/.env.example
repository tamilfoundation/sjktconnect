# Django settings
DJANGO_SETTINGS_MODULE=sjktconnect.settings.development
SECRET_KEY=your-secret-key-here

# Database (Neon PostgreSQL)
# Get from Neon console: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Production only
# ALLOWED_HOSTS=tamilschool.org,sjktconnect-api-xxxxx.run.app
# CSRF_TRUSTED_ORIGINS=https://tamilschool.org

# Sprint 0.4+
# GEMINI_API_KEY=your-gemini-api-key

# TD-21 (Sprint 29) — server-driven ISR revalidation.
# When set, the Django backend POSTs to the Next.js route handler
# (frontend/app/api/revalidate/route.ts) after a successful school/
# leader edit. The route handler validates the X-Revalidate-Token
# header against REVALIDATE_TOKEN (set on the WEB Cloud Run service
# with the same value).
# REVALIDATE_WEBHOOK_URL=https://tamilschool.org/api/revalidate
# REVALIDATE_TOKEN=<opaque-secret-shared-between-api-and-web>

